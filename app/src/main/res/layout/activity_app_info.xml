<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/appInfoTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_info_title"
                android:textColor="@color/colorTextPrimary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/appInfoHelpButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_info_need_help"
                app:icon="@drawable/ic_help_placeholder"
                app:iconSize="20dp"
                app:iconTint="@color/colorAccent" />
        </LinearLayout>

        <TextView
            android:id="@+id/appInfoSubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/app_info_subtitle"
            android:textColor="@color/colorTextSecondary"
            android:textSize="14sp" />

        <!-- About App Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/colorSurfaceVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_info_about_app_title"
                    android:textColor="@color/colorAccent"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/app_info_what_does_it_do"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:textStyle="italic" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/app_info_about_app_body"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openGithubRepoButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/app_info_github_repo_button"
                        android:textColor="@color/colorAccent"
                        app:icon="@drawable/ic_github"
                        app:iconTint="@color/colorAccent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openGitlabRepoButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/app_info_gitlab_repo_button"
                        android:textColor="@color/colorAccent"
                        app:icon="@drawable/ic_gitlab"
                        app:iconTint="@color/colorAccent" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- About Developer Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/colorSurfaceVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_info_about_dev_title"
                    android:textColor="@color/colorAccent"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/avatarImage"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@color/colorSurfaceVariant"
                        android:contentDescription="@string/app_info_avatar_description"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.Circle"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp" />

                    <TextView
                        android:id="@+id/developerNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/app_info_name"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/developerUsernameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/app_info_username"
                        android:textColor="@color/colorAccent"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/avatarStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/app_info_avatar_loading"
                        android:textColor="@color/colorTextMuted"
                        android:textSize="11sp"
                        android:visibility="gone" />
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:dividerColor="@color/colorSurfaceVariant" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:columnCount="2"
                    android:rowCount="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openGithubButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="start|center_vertical"
                        android:text="@string/app_info_github_button"
                        android:textColor="@color/colorTextSecondary"
                        app:icon="@drawable/ic_github"
                        app:iconPadding="8dp"
                        app:iconTint="@color/colorTextSecondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openXButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="start|center_vertical"
                        android:text="@string/app_info_x_button"
                        android:textColor="@color/colorTextSecondary"
                        app:icon="@drawable/ic_x"
                        app:iconPadding="8dp"
                        app:iconTint="@color/colorTextSecondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openLinkedinButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="start|center_vertical"
                        android:text="@string/app_info_linkedin_button"
                        android:textColor="@color/colorTextSecondary"
                        app:icon="@drawable/ic_linkedin"
                        app:iconPadding="8dp"
                        app:iconTint="@color/colorTextSecondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openDevToButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="start|center_vertical"
                        android:text="@string/app_info_devto_button"
                        android:textColor="@color/colorTextSecondary"
                        app:icon="@drawable/ic_devto"
                        app:iconPadding="8dp"
                        app:iconTint="@color/colorTextSecondary" />

                </GridLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
