<resources>
    <style name="Theme.DhwaniControl" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Core colors mapping -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorTextPrimary</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/colorTextSecondary</item>
        <item name="colorError">@color/colorWarning</item>
        <item name="colorOnError">@color/colorBackground</item>
        <item name="colorOutline">@color/colorSurfaceVariant</item>

        <!-- System UI -->
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="ShapeAppearanceOverlay.Material3.Circle" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>
