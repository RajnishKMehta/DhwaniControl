    <string name="quick_tile_guide_intro">Swipe left or right to move between steps. Use the buttons below if you prefer tapping.</string>
    <string name="quick_tile_guide_step_1_title">Step 1: Open Quick Settings</string>
    <string name="quick_tile_guide_step_1_body">Swipe down from the top of the screen once, then swipe down again to fully expand Quick Settings.</string>
    <string name="quick_tile_guide_step_1_image_url">https://raw.githubusercontent.com/RajnishKMehta/images/refs/heads/main/DhwaniControl/quick-tile-step-1.webp</string>
    <string name="quick_tile_guide_step_2_title">Step 2: Enter Edit Mode</string>
    <string name="quick_tile_guide_step_2_body">Tap the edit control, usually a pencil icon or an Edit tiles button.</string>
    <string name="quick_tile_guide_step_2_image_url">https://raw.githubusercontent.com/RajnishKMehta/images/refs/heads/main/DhwaniControl/quick-tile-step-2.webp</string>
    <string name="quick_tile_guide_step_3_title">Step 3: Add the Tile</string>
    <string name="quick_tile_guide_step_3_body">Find Volume Panel from DhwaniControl and drag it into your active tiles area.</string>
    <string name="quick_tile_guide_step_3_image_url">https://raw.githubusercontent.com/RajnishKMehta/images/refs/heads/main/DhwaniControl/quick-tile-step-3.webp</string>
    <string name="quick_tile_guide_step_4_title">Step 4: Save and Test</string>
    <string name="quick_tile_guide_step_4_body">Save the layout, exit edit mode, then tap Volume Panel to open Android volume controls.</string>
    <string name="quick_tile_guide_step_4_image_url">https://raw.githubusercontent.com/RajnishKMehta/images/refs/heads/main/DhwaniControl/quick-tile-step-4.webp</string>
