    <string name="quick_tile_guide_step_3_title">Step 3: Add Volume Panel Tile</string>
    <string name="quick_tile_guide_step_3_body">Find "Volume Panel" from DhwaniControl and drag it into your active tiles.</string>
    <string name="quick_tile_guide_step_3_image_url">https://example.com/quick-tile-step-3.png</string>
