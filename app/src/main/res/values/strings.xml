    <string name="app_info_title">App Info</string>
    <string name="app_info_subtitle">Learn more about the app and the developer</string>
    <string name="app_info_about_app_title">About DhwaniControl</string>
    <string name="app_info_about_app_body">I have built this app because my phone\'s physical volume buttons are broken. It is frustrating to go to settings every time I want to change the volume. I build this for myself and open-source it so that anyone facing similar issues can use it easily through gestures or quick tiles.</string>
    <string name="app_info_about_dev_title">About the Developer</string>
    <string name="app_info_intro">I am the developer of this app. I built DhwaniControl to solve a real-world problem I was facing, and I continue to maintain it as an open-source project for the community.</string>
